# ── Shared (all patterns) ─────────────────────────────────────────────────
# Your Databricks workspace URL — found in the browser address bar
DATABRICKS_HOST=https://dbc-xxxx-yyyy.cloud.databricks.com/

# Personal access token — Databricks UI > Settings > Developer > Access tokens
DATABRICKS_CONNECTION_TOKEN=dapi...

# ── Pattern 1: Databricks Connect ─────────────────────────────────────────
# No extra vars needed — uses DATABRICKS_HOST + DATABRICKS_CONNECTION_TOKEN above

# ── Pattern 2: Dagster Pipes ──────────────────────────────────────────────
# Job ID of the feature engineering notebook in Databricks Workflows
# Find it: Workflows > click your job > ID in the URL
DATABRICKS_NOTEBOOK_JOB_ID=

# ── Pattern 3: Workspace Component ────────────────────────────────────────
# Optional: filter to a specific job ID (all jobs discovered if not set)
# Find it: Workflows > click your job > the ID is in the URL (?o=...#job/12345)
# DATABRICKS_JOB_ID=

# ── CI/CD (GitHub Actions + AWS CodeBuild) ────────────────────────────────
# Set these as GitHub repository variables (not secrets) — Settings > Variables
AWS_REGION=us-west-2
ECR_REGISTRY=                  # e.g. 123456789012.dkr.ecr.us-west-2.amazonaws.com
ECR_REPO_NAME=databricks-demo
# AWS credentials go in GitHub Secrets (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# DAGSTER_CLOUD_API_TOKEN also goes in GitHub Secrets

# ── Local testing (skips real Databricks calls) ───────────────────────────
# Set to true to run all patterns with synthetic mock data — no Databricks account needed
DEMO_MODE=false
